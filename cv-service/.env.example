# Cloudinary settings
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SAM2 Settings
# For Render Free Tier (512MB RAM), set to "true" to bypass SAM2 entirely and use polygon fallback,
# OR use the tiny model (which consumes much less memory than the default small model):
DISABLE_SAM2=false
SAM2_CHECKPOINT=checkpoints/sam2_hiera_tiny.pt
SAM2_CONFIG=sam2_hiera_t.yaml

# General settings
ALLOWED_ORIGINS=http://localhost:3000
PORT=8000

